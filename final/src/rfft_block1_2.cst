// ============================================================
// Pin constraints - Block1+Block2 fusion (Tang Primer 20K Dock)
// Device: GW2A-LV18PG256C8/I7
//
// Hito intermedio (solo B1+B2). Pines onboard verificados contra el
// repo oficial de Sipeed (UART_HELLO + Litex BSP). NINGUN pin colisiona
// con el conector RGB LCD del Dock, asi que es seguro flashear este
// bitstream con el LCD conectado.
//
// FIX: la version anterior usaba E15/A15/D14/E10/R9/D10, que son TODOS
// pines del LCD (lcd_de/lcd_hsync/lcd_vsync/lcd_bl/lcd_clk/lcd_g5).
// Eso podia danar el LCD o cortocircuitar senales.
//
// br_real[15:0] / br_imag[15:0] quedan SIN constrain a proposito (solo
// existen para que la sintesis conserve el datapath; sondearlos con
// analizador logico requiere asignarles pines de un header libre).
// Gowin P&R los auto-coloca (solo warning).
// ============================================================

IO_LOC "clk" H11;
IO_PORT "clk" PULL_MODE=UP IO_TYPE=LVCMOS33;

// --- entradas ---
IO_LOC "rst_n" T10;          // btn_n0 (boton onboard, activo-bajo)
IO_PORT "rst_n" PULL_MODE=UP IO_TYPE=LVCMOS33;
IO_LOC "uart_rx" T13;        // UART RX del FPGA (ESP32 TX)
IO_PORT "uart_rx" PULL_MODE=UP IO_TYPE=LVCMOS33;
IO_LOC "br_ready" T3;        // btn_n1 (jumper a 3V3 / boton para liberar)
IO_PORT "br_ready" PULL_MODE=UP IO_TYPE=LVCMOS15;

// --- salidas (LEDs onboard) ---
IO_LOC "br_valid" L16;       // led0
IO_PORT "br_valid" PULL_MODE=UP DRIVE=8 IO_TYPE=LVCMOS33;
IO_LOC "fifo_overflow" L14;  // led1
IO_PORT "fifo_overflow" PULL_MODE=UP DRIVE=8 IO_TYPE=LVCMOS33;
IO_LOC "frame_dropped" N14;  // led2
IO_PORT "frame_dropped" PULL_MODE=UP DRIVE=8 IO_TYPE=LVCMOS33;
